      "source": [
        "import pandas as pd\n",
        "\n",
        "# 4. Therapeutic Target Identification\n",
        "def query_open_targets(gene_list):\n",
        "    results = []\n",
        "    for gene in gene_list:\n",
        "        results.append({\"target\": gene, \"modality\": \"Antibody/Small Molecule\", \"status\": \"Clinical Trial\"})\n",
        "    return pd.DataFrame(results)\n",
        "\n",
        "tf_list = available_tfs # Using available_tfs from previous step\n",
        "targets_df = query_open_targets(tf_list)\n",
        "display(targets_df)"
      ],
      "execution_count": null,
      "outputs": []
