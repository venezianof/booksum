      "source": [
        "import json\n",
        "import os\n",
        "from pathlib import Path\n",
        "\n",
        "def fix_notebook_colab(filepath):\n",
        "    try:\n",
        "        with open(filepath, 'r', encoding='utf-8') as f:\n",
        "            notebook = json.load(f)\n",
        "\n",
        "        # Rimuove i metadata dei widgets se presenti\n",
        "        if 'metadata' in notebook and 'widgets' in notebook['metadata']:\n",
        "            del notebook['metadata']['widgets']\n",
        "            print(f\"✓ Sezione 'widgets' rimossa da: {filepath}\")\n",
        "        else:\n",
        "            print(f\"ℹ Nessuna sezione 'widgets' trovata in: {filepath}\")\n",
        "\n",
        "        # Salva il file pulito\n",
        "        with open(filepath, 'w', encoding='utf-8') as f:\n",
        "            json.dump(notebook, f, indent=2)\n",
        "\n",
        "        return True\n",
        "    except Exception as e:\n",
        "        print(f\"✗ Errore durante l'elaborazione di {filepath}: {e}\")\n",
        "        return False\n",
        "\n",
        "# Scansione automatica della cartella /content/\n",
        "notebooks = [f for f in os.listdir('.') if f.endswith('.ipynb')]\n",
        "\n",
        "if not notebooks:\n",
        "    print(\"Nessun file .ipynb trovato in /content/.\")\n",
        "    print(\"Suggerimento: Carica un file .ipynb usando l'icona della cartella a sinistra per processarlo.\")\n",
        "else:\n",
        "    for nb in notebooks:\n",
        "        fix_notebook_colab(nb)\n",
        "    print(\"\\nProcesso di pulizia completato.\")"
      ],
