        "        status = \"Compatibile / Safe\"\n",
        "        action = \"Dosaggio Standard\"\n",
        "\n",
        "    correlation_data.append({\n",
        "        \"Trial_ID\": tid,\n",
        "        \"Target\": trial['Target'],\n",
